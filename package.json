        "css-loader": "^7.1.2",
        "eslint": "^8.57.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.31.0",
        "gh-pages": "^6.3.0",
        "html-webpack-plugin": "^5.6.3",
        "jest": "^29.7.0",
        "style-loader": "^4.0.0",
        "webpack": "^5.98.0",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.0"
    }
