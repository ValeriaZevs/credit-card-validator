{
    "name": "credit-card-validator",
    "version": "1.0.0",
    "description": "Credit Card Validator widget",
    "private": true,
    "scripts": {
        "start": "node ./node_modules/webpack-dev-server/bin/webpack-dev-server.js --mode development --no-open",
        "build": "node ./node_modules/webpack/bin/webpack.js --mode production",
        "lint": "node ./node_modules/eslint/bin/eslint.js .",
        "test": "node ./node_modules/jest/bin/jest.js --coverage",
